PORT=5003
MONGODB_URI=mongodb://127.0.0.1:27017/insurance_management
# Required — login fails with 500 if this is missing or empty on the API server
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=development
# Optional SMS (Waafi/Hormuud style HTTP API)
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=
# Optional web push (VAPID) — generate keys for production
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
