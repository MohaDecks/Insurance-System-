PORT=5003
MONGODB_URI=mongodb://127.0.0.1:27017/insurance_management
# Optional — if empty, a built-in default is used (set your own in production)
JWT_SECRET=
JWT_EXPIRES_IN=7d
NODE_ENV=development
# npm run seed (requires SEED_CONFIRM=yes) — wipes this database
# SEED_ADMIN_EMAIL=admin@insurance.local
# SEED_ADMIN_PASSWORD=ChangeMe123!
# SEED_SUPER_EMAIL=deq@gmail.com
# SEED_SUPER_PASSWORD=ChangeMe123!
# Optional SMS (Waafi/Hormuud style HTTP API)
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=
# Optional web push (VAPID) — generate keys for production
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
